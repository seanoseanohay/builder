# Anthropic API key (optional if using OpenRouter). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (one key for Claude, GPT, Grok, etc.). Get one at https://openrouter.ai/
# Use this for the pipeline (refiner, projgen, consensus) to avoid provider rate limits.
OPENROUTER_API_KEY=sk-or-...

# LangSmith (optional): trace LLM traffic for monitoring and debugging.
# Get key at https://smith.langchain.com/ → Settings → API Keys. Project name defaults to "default".
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=builder-pipeline

# No-code option: in OpenRouter dashboard → Settings → Observability → Enable Broadcast → LangSmith,
# then all OpenRouter traffic is traced to LangSmith without these env vars.
